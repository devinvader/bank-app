{
  "request": {
    "method": "POST",
    "url": "/api/cash/deposit",
    "headers": {
      "Authorization": {
        "matches": "Bearer .*"
      },
      "Content-Type": {
        "contains": "application/json"
      }
    },
    "bodyPatterns": [
      { "matchesJsonPath": "$[?(@.amount > 0)]" }
    ]
  },
  "response": {
    "status": 200,
    "headers": {
      "Content-Type": "application/json"
    },
    "jsonBody": {
      "accountId": "afd94176-3179-4285-9f6b-96fd9131628a",
      "newBalance": 1100.00,
      "type": "DEPOSIT",
      "amount": 100.00
    }
  }
}
