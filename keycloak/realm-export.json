{
  "id": "bank",
  "realm": "bank",
  "enabled": true,
  "displayName": "Bank Realm",
  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,
  "offlineSessionIdleTimeout": 2592000,
  "accessCodeLifespan": 60,
  "accessCodeLifespanUserAction": 300,
  "accessCodeLifespanLogin": 1800,
  "users": [
    {
      "username": "user1",
      "email": "user1@bank.local",
      "firstName": "Иван",
      "lastName": "Иванов",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password"
        }
      ]
    },
    {
      "username": "user2",
      "email": "user2@bank.local",
      "firstName": "Петр",
      "lastName": "Петров",
      "enabled": true,
      "credentials": [
        {
          "type": "password",
          "value": "password"
        }
      ]
    }
  ],
  "clients": [
    {
      "clientId": "bank-front-ui",
      "name": "Bank Front UI",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "redirectUris": [
        "http://localhost:8080/login/oauth2/code/keycloak",
        "http://localhost:8080/*"
      ],
      "webOrigins": ["http://localhost:8080", "+"],
      "defaultClientScopes": ["openid", "profile", "web-origins", "email",
        "accounts:read", "accounts:write",
        "cash:operate",
        "transfer:execute"],
      "optionalClientScopes": [],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:8080/*"
      }
    },
    {
      "clientId": "bank-gateway",
      "name": "Bank Gateway",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "gateway-secret",
      "bearerOnly": true,
      "defaultClientScopes": [],
      "optionalClientScopes": []
    },
    {
      "clientId": "bank-accounts",
      "name": "Bank Accounts Service",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "secret": "accounts-secret",
      "bearerOnly": false,
      "defaultClientScopes": [],
      "optionalClientScopes": ["notifications:send"],
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING"
      }
    },
    {
      "clientId": "bank-cash",
      "name": "Bank Cash Service",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "secret": "cash-secret",
      "bearerOnly": false,
      "defaultClientScopes": [],
      "optionalClientScopes": ["accounts:read", "accounts:write", "notifications:send"],
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING"
      }
    },
    {
      "clientId": "bank-transfer",
      "name": "Bank Transfer Service",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "authorizationServicesEnabled": true,
      "secret": "transfer-secret",
      "bearerOnly": false,
      "defaultClientScopes": [],
      "optionalClientScopes": ["accounts:read", "accounts:write", "notifications:send", "transfer:execute"],
      "authorizationSettings": {
        "allowRemoteResourceManagement": true,
        "policyEnforcementMode": "ENFORCING"
      }
    },
    {
      "clientId": "bank-notifications",
      "name": "Bank Notifications Service",
      "publicClient": false,
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "authorizationServicesEnabled": false,
      "secret": "notifications-secret",
      "bearerOnly": true,
      "defaultClientScopes": [],
      "optionalClientScopes": []
    }
  ],
  "clientScopes": [
    {
      "name": "accounts:read",
      "description": "Scope for reading account data",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      },
      "protocolMappers": [
        {
          "name": "accounts_read_mapper",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "consentRequired": false,
          "config": {
            "claim.name": "scope",
            "claim.value": "accounts:read",
            "access.token.claim": "true",
            "id.token.claim": "false",
            "lightweight.claim": "false"
          }
        }
      ]
    },
    {
      "name": "accounts:write",
      "description": "Scope for writing account data",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "notifications:send",
      "description": "Scope for sending notifications",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "transfer:execute",
      "description": "Scope for executing transfers",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    },
    {
      "name": "cash:operate",
      "description": "Scope for cash operations",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true",
        "display.on.consent.screen": "true"
      }
    }
  ]
}
